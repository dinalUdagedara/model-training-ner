%% Class Diagram - CrackInt Backend
%% Chapter 6, Section 6.4
%% id / timestamps on each class (mixins in code). Links R1–R6 match HTML figure + table.
%% Render: mmdc -i 04-class-diagram.mmd -o 04-class-diagram-mermaid.png

classDiagram
    direction LR

    class User {
        +UUID id
        +datetime created_at
        +datetime updated_at
        +str name
        +str email
        +str hashed_password
    }

    class Resume {
        +UUID id
        +datetime created_at
        +datetime updated_at
        +UUID user_id
        +dict entities
        +str raw_text
        +float cv_score
    }

    class JobPosting {
        +UUID id
        +datetime created_at
        +datetime updated_at
        +UUID user_id
        +dict entities
        +str raw_text
        +str location
        +datetime deadline
    }

    class PrepSession {
        +UUID id
        +datetime created_at
        +datetime updated_at
        +UUID user_id
        +UUID resume_id
        +UUID job_posting_id
        +str mode
        +str status
        +float readiness_score
        +dict summary
    }

    class Message {
        +UUID id
        +datetime created_at
        +datetime updated_at
        +UUID session_id
        +str sender
        +str type
        +str content
        +dict meta
    }

    User "1" --> "*" Resume : R1
    User "1" --> "*" JobPosting : R2
    User "1" --> "*" PrepSession : R3
    Resume "1" --> "*" PrepSession : R4
    JobPosting "1" --> "*" PrepSession : R5
    PrepSession "1" --> "*" Message : R6
